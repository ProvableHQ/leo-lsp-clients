{
  "name": "leo-extension",
  "displayName": "Leo",
  "version": "0.49.0",
  "publisher": "aleohq",
  "description": "The official VS Code extension for Leo",
  "license": "SEE LICENSE IN LICENSE.txt",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "aleo",
    "leo"
  ],
  "galleryBanner": {
    "color": "#931CFF",
    "theme": "dark"
  },
  "preview": false,
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:leo",
    "onCommand:leo-extension.about"
  ],
  "contributes": {
    "languages": [
      {
        "id": "leo",
        "aliases": [
          "Leo",
          "leo"
        ],
        "extensions": [
          ".leo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "leo",
        "scopeName": "source.leo",
        "path": "./syntaxes/leo.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "leo-extension.about",
        "title": "Leo About"
      }
    ],
    "configuration": {
      "title": "Leo",
      "properties": {
        "leo.languageServer.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute or workspace-relative path to the `leo-lsp` executable. When unset, the extension searches common local development locations and `PATH`."
        },
        "leo.languageServer.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional arguments passed to the Leo language server executable."
        }
      }
    }
  },
  "badges": [
    {
      "url": "https://img.shields.io/twitter/follow/AleoHQ?style=social",
      "href": "https://twitter.com/AleoHQ",
      "description": "Twitter"
    },
    {
      "url": "https://img.shields.io/discord/700454073459015690?logo=discord",
      "href": "https://discord.com/invite/aleo",
      "description": "Discord"
    }
  ],
  "markdown": "github",
  "qna": "marketplace",
  "scripts": {
    "build": "npm run typecheck && npm run clean && npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js --sourcemap",
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "typecheck": "tsc -p . --noEmit",
    "watch": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js --sourcemap --watch",
    "package": "vsce package --no-dependencies -o ../../dist/leo-extension.vsix",
    "publish:extension": "vsce publish --no-dependencies -p $VSCODE_PUBLISHER_TOKEN"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "icon": "icons/leo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ProvableHQ/leo-lsp-clients.git"
  },
  "bugs": {
    "url": "https://github.com/ProvableHQ/leo-lsp-clients/issues"
  },
  "homepage": "https://leo-lang.org/",
  "author": "aleohq",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^2.19.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.1.3"
  }
}
